{
  "name": "zimplifyed-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx scripts/worker.ts",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:check": "tsx scripts/check-schema-safety.ts",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "promote": "tsx scripts/promote-super-admin.ts",
    "eval:ai": "tsx src/tests/ai/run.ts",
    "test:security": "tsx --conditions=react-server src/tests/security/vault.test.ts && tsx --conditions=react-server src/tests/security/tenant-isolation.test.ts",
    "test:doc-engine": "tsx --conditions=react-server src/tests/doc-engine/golden.ts",
    "test:billing": "tsx src/tests/billing/lifecycle.test.ts",
    "test:pnl": "tsx src/tests/order-pnl/expenses.test.ts",
    "test:gst-prep": "tsx src/tests/gst-prep/prep-pack.test.ts",
    "test:landed-cost": "tsx src/tests/pricing/landed-cost.test.ts",
    "test:pricing": "tsx src/tests/pricing/pricing-buildup.test.ts",
    "test:compliance": "tsx src/tests/compliance/deadlines.test.ts",
    "test:access": "tsx src/tests/access/permissions.test.ts",
    "test:integration": "tsx --conditions=react-server src/tests/integration/features.test.ts",
    "test": "npm run test:billing && npm run test:pnl && npm run test:landed-cost && npm run test:pricing && npm run test:compliance && npm run test:access && npm run test:security && npm run test:doc-engine",
    "ingest:corpus": "tsx scripts/ingest-corpus.ts",
    "billing:sweep": "tsx scripts/billing-lifecycle-sweep.ts",
    "compliance:sweep": "tsx scripts/compliance-expiry-sweep.ts",
    "followup:sweep": "tsx --conditions=react-server scripts/quote-followup-sweep.ts",
    "inbox:sync-sweep": "tsx --conditions=react-server scripts/inbox-sync-sweep.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.17.2",
    "server-only": "^0.0.1",
    "stripe": "^22.3.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
